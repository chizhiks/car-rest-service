{
  "realm": "car-rest-service",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "USER", "description": "Standard application user" },
      { "name": "ADMIN", "description": "Administrative user" }
    ]
  },
  "clients": [
    {
      "clientId": "car-rest-service",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "demo-user",
      "enabled": true,
      "email": "demo-user@example.com",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "demo-pass123", "temporary": false }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "demo-admin",
      "enabled": true,
      "email": "demo-admin@example.com",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "demo-pass123", "temporary": false }
      ],
      "realmRoles": ["ADMIN", "USER"]
    }
  ]
}